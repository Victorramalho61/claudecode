<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS Reverse Proxy — Jarvis / Voetur
  Requisitos: ARR (Application Request Routing) + URL Rewrite instalados.
  Habilitar proxy: IIS Manager → Application Request Routing → Server Proxy Settings → Enable proxy

  Roteamento:
    /api/*  →  FastAPI container em localhost:8000
    /*      →  nginx/React SPA em localhost:8080
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>

        <!-- Backend: /api/* → FastAPI (porta 8000) -->
        <rule name="Backend API" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:8000/api/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
          </serverVariables>
        </rule>

        <!-- Frontend SPA: tudo mais → nginx container (porta 8080) -->
        <rule name="Frontend SPA" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:8080/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
          </serverVariables>
        </rule>

      </rules>
    </rewrite>

    <!-- Deixa o ARR processar tudo — sem interferência do handler de arquivos estáticos -->
    <handlers>
      <remove name="StaticFile" />
      <remove name="DirectoryListings" />
    </handlers>

  </system.webServer>
</configuration>
