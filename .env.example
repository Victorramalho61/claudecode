# ── Backend ──────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-key>          # nunca exponha no frontend

# ── Frontend (Vite) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>        # seguro para o frontend
VITE_API_URL=http://localhost:8000

# ── GitHub Actions Secrets ───────────────────────────────────────────
# SUPABASE_URL          → mesmo que backend
# SUPABASE_KEY          → mesmo que backend
# VITE_SUPABASE_URL     → mesmo que frontend
# VITE_SUPABASE_ANON_KEY→ mesmo que frontend
# VITE_API_URL          → URL pública do backend em produção
#
# VERCEL_TOKEN          → token em vercel.com/account/tokens
# VERCEL_ORG_ID         → Settings > General no dashboard da Vercel
# VERCEL_PROJECT_ID     → Settings > General no projeto Vercel
#
# SSH_HOST              → IP ou hostname do servidor
# SSH_USER              → usuário SSH (ex: ubuntu)
# SSH_PRIVATE_KEY       → chave privada SSH (cat ~/.ssh/id_rsa)
